<?xml version="1.0" encoding="utf-8"?>
<!--
    Permissões privilegiadas para o Android Auto (com.google.android.projection.gearhead)
    Necessárias para que o Android Auto funcione como app de sistema (priv-app).
    Baseado na lista oficial do AOSP/GMS para Android 12-16.
-->
<permissions>
    <privapp-permissions package="com.google.android.projection.gearhead">
        <!-- Acesso a informações de rede -->
        <permission name="android.permission.ACCESS_NETWORK_CONDITIONS"/>
        <!-- Embedding de atividades -->
        <permission name="android.permission.ACTIVITY_EMBEDDING"/>
        <!-- Bluetooth privilegiado (pareamento, perfis HFP/A2DP) -->
        <permission name="android.permission.BLUETOOTH_PRIVILEGED"/>
        <!-- Chamadas privilegiadas (integração com sistema de telefonia do carro) -->
        <permission name="android.permission.CALL_PRIVILEGED"/>
        <!-- Captura de áudio hotword (OK Google no carro) -->
        <permission name="android.permission.CAPTURE_AUDIO_HOTWORD"/>
        <!-- Captura de saída de áudio -->
        <permission name="android.permission.CAPTURE_AUDIO_OUTPUT"/>
        <!-- Alteração de whitelist de idle do dispositivo -->
        <permission name="android.permission.CHANGE_DEVICE_IDLE_TEMP_WHITELIST"/>
        <!-- Companion device - conexões Wi-Fi -->
        <permission name="android.permission.COMPANION_APPROVE_WIFI_CONNECTIONS"/>
        <!-- Rede interna do sistema -->
        <permission name="android.permission.CONNECTIVITY_INTERNAL"/>
        <!-- Controle de experiência em chamada -->
        <permission name="android.permission.CONTROL_INCALL_EXPERIENCE"/>
        <!-- Dump de informações de diagnóstico -->
        <permission name="android.permission.DUMP"/>
        <!-- Obter contas privilegiado -->
        <permission name="android.permission.GET_ACCOUNTS_PRIVILEGED"/>
        <!-- Interação entre usuários -->
        <permission name="android.permission.INTERACT_ACROSS_USERS"/>
        <!-- Acesso ao endereço MAC local -->
        <permission name="android.permission.LOCAL_MAC_ADDRESS"/>
        <!-- Hardware de localização -->
        <permission name="android.permission.LOCATION_HARDWARE"/>
        <!-- Gerenciamento de detentores de papel (roles) -->
        <permission name="android.permission.MANAGE_ROLE_HOLDERS"/>
        <!-- Gerenciamento de USB -->
        <permission name="android.permission.MANAGE_USB"/>
        <!-- Roteamento de áudio (para o sistema de som do carro) -->
        <permission name="android.permission.MODIFY_AUDIO_ROUTING"/>
        <!-- Modificar modo dia/noite -->
        <permission name="android.permission.MODIFY_DAY_NIGHT_MODE"/>
        <!-- Modificar estado do telefone -->
        <permission name="android.permission.MODIFY_PHONE_STATE"/>
        <!-- Notificar atualização de sistema pendente -->
        <permission name="android.permission.NOTIFY_PENDING_SYSTEM_UPDATE"/>
        <!-- Observar concessão/revogação de permissões -->
        <permission name="android.permission.OBSERVE_GRANT_REVOKE_PERMISSIONS"/>
        <!-- Estatísticas de uso de pacotes -->
        <permission name="android.permission.PACKAGE_USAGE_STATS"/>
        <!-- Leitura privilegiada do estado do telefone -->
        <permission name="android.permission.READ_PRIVILEGED_PHONE_STATE"/>
        <!-- Obter tarefas reais -->
        <permission name="android.permission.REAL_GET_TASKS"/>
        <!-- Registrar provedor de chamadas -->
        <permission name="android.permission.REGISTER_CALL_PROVIDER"/>
        <!-- Definir listener de tecla de volume (long press) -->
        <permission name="android.permission.SET_VOLUME_KEY_LONG_PRESS_LISTENER"/>
        <!-- Iniciar atividades em background -->
        <permission name="android.permission.START_ACTIVITIES_FROM_BACKGROUND"/>
        <!-- Iniciar tarefas de recentes -->
        <permission name="android.permission.START_TASKS_FROM_RECENTS"/>
        <!-- Toggle de projeção automotiva -->
        <permission name="android.permission.TOGGLE_AUTOMOTIVE_PROJECTION"/>
        <!-- Atualizar estatísticas de operações de app -->
        <permission name="android.permission.UPDATE_APP_OPS_STATS"/>
        <!-- Escrever configurações seguras -->
        <permission name="android.permission.WRITE_SECURE_SETTINGS"/>
    </privapp-permissions>
</permissions>
